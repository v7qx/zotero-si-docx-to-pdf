pref-title = Docx to PDF Settings
pref-description = Convert a new child DOC or DOCX attachment only when its parent item already has a sibling PDF attachment.
pref-deleteOriginal =
    .label = Delete the original DOC / DOCX attachment after a successful conversion
pref-deleteOriginal-note = If enabled, delete the original child DOC / DOCX attachment after a successful PDF import.
pref-backupBeforeDelete =
    .label = Back up the original DOC / DOCX attachment before deletion
pref-backupDirectory = Backup folder
pref-backupDirectory-browse =
    .label = Browse...
pref-backupDirectory-note = Backups are stored in a docx-to-pdf-backups folder inside the selected directory. Leave empty to use the Zotero data directory.
pref-titleTemplate = PDF title/filename template using Zotero's official file-renaming syntax
pref-titleTemplate-note = Uses parent-item metadata to generate the PDF title and filename.
pref-renameMode = Rename mode
pref-renameMode-titleOnly =
    .label = Title only
pref-renameMode-titleAndFile =
    .label = Title and filename
pref-renameMode-note = When multiple DOC / DOCX files would generate the same name, a numeric suffix is appended. Long filenames are truncated automatically.
pref-backend = Conversion backend
pref-backend-libreoffice =
    .label = LibreOffice
pref-backend-word =
    .label = Microsoft Word (Windows only)
pref-libreOfficePath = LibreOffice executable path (Windows: soffice.exe; Linux/macOS: soffice or libreoffice)
pref-libreOfficePath-browse =
    .label = Browse...
pref-showNotifications =
    .label = Show conversion result notifications
pref-restrictByKeywords =
    .label = Process only DOC / DOCX attachments whose filename matches the keyword rule
pref-keywordPattern = Keyword regex
pref-keywordPattern-note = Matched against the DOC / DOCX filename only.
pref-help = { $name } { $version }
