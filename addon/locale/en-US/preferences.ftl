pref-title = Word to PDF Settings
pref-description = Convert a new child Word attachment only when its parent item already has a sibling PDF attachment.
pref-deleteOriginal =
    .label = Delete the original Word attachment after a successful conversion
pref-deleteOriginal-note = If enabled, delete the original child Word attachment after a successful PDF import.
pref-backupBeforeDelete =
    .label = Back up the original Word attachment before deletion
pref-backupBeforeDelete-note = Backups are stored in the word-to-pdf-backups folder inside the Zotero data directory.
pref-backupDirectory = Backup folder
pref-backupDirectory-browse =
    .label = Browse...
pref-backupDirectory-note = Leave empty to use the default word-to-pdf-backups folder inside the Zotero data directory.
pref-titleTemplate = PDF title/filename template using Zotero's official file-renaming syntax
pref-titleTemplate-note = Uses parent-item metadata to generate the PDF title and filename.
pref-backend = Conversion backend
pref-backend-auto =
    .label = Auto
pref-backend-libreoffice =
    .label = LibreOffice
pref-backend-word =
    .label = Microsoft Word (Windows only)
pref-libreOfficePath = LibreOffice executable path
pref-libreOfficePath-browse =
    .label = Browse...
pref-showNotifications =
    .label = Show conversion result notifications
pref-restrictByKeywords =
    .label = Process only Word attachments whose filename matches the keyword rule
pref-keywordPattern = Keyword regex
pref-keywordPattern-note = Matched against the Word filename only.
pref-help = { $name } { $version }
